# Database
DATABASE_URL="file:./src/prisma/wealth-plus.db"

# JWT — access token signing secret (must be at least 32 random characters)
JWT_SECRET="replace-this-with-at-least-32-random-characters-now"

# JWT — refresh token signing secret (must be at least 32 random characters, different from JWT_SECRET)
JWT_REFRESH_SECRET="replace-this-with-a-different-32-char-refresh-secret"

# JWT expiry durations (jsonwebtoken format: 15m, 7d, 1h, etc.)
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
CLIENT_ORIGIN="http://localhost:5173,http://localhost:4000"

# Rate limiting (in milliseconds and request count)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10

# Seed passwords (used by npm run seed — change these before seeding)
SEED_USER1_PASSWORD="ChangeMe001!"
SEED_USER2_PASSWORD="ChangeMe002!"
